# ── Copy this to .env and fill in your values ──────────────────
# cp .env.example .env

# ── Frontend ────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── Backend ──────────────────────────────────────────────────────
# API key for programmatic access (super-user mode, no user isolation)
# Leave blank to disable (local dev only).
SENTINEL_API_KEY=

# ── JWT Auth ─────────────────────────────────────────────────────
# Secret for signing JWT tokens. CHANGE THIS IN PRODUCTION!
JWT_SECRET=dev-secret-change-in-prod-$(openssl rand -hex 32)
JWT_EXPIRY_DAYS=7

# ── Ollama (LLM runtime) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
PLANNER_MODEL=llama3.1:8b
SECURITY_MODEL=llama3.1:8b
DEEP_SCAN_MODEL=llama3.1:8b
SYNTHESIS_MODEL=llama3.1:8b
TEST_GENERATION_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Database ─────────────────────────────────────────────────────
SENTINEL_DB_PATH=/data/sentinel.db
