# ── Copy this to .env and fill in your values ──────────────────
# cp .env.example .env

# ── Frontend ────────────────────────────────────────────────────
# URL of your deployed backend (used at React build time)
# For local dev:        http://localhost:8000
# For org deployment:   https://sentinel.yourcompany.internal
REACT_APP_API_URL=http://localhost:8000

# ── Backend ─────────────────────────────────────────────────────
# API key users must send in X-API-Key header.
# Leave blank to disable auth (local dev only).
SENTINEL_API_KEY=

# Anthropic API key — enables AI analysis tab in reports.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# CORS allowed origins (comma-separated).
# Use * for dev. In production: https://sentinel.yourcompany.com
ALLOWED_ORIGINS=*
