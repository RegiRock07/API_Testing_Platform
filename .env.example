# ── Copy this to .env and fill in your values ──────────────────
# cp .env.example .env

# ── Frontend ────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── Backend auth ─────────────────────────────────────────────────
# Leave blank to disable auth (local dev only)
SENTINEL_API_KEY=

# ── LLM Configuration ────────────────────────────────────────────
# LLM_PROVIDER: "groq" (default, cloud) or "ollama" (local/offline)
LLM_PROVIDER=groq

# ── Groq (Primary Provider) ──────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the model (default is llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2

# ── Ollama (Fallback — local/offline dev) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60

# ── CORS ─────────────────────────────────────────────────────────
# Use * for dev. In production: https://yourfrontend.com
ALLOWED_ORIGINS=*

# ── Database ─────────────────────────────────────────────────────
SENTINEL_DB_PATH=/data/sentinel.db
